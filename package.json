{
  "name": "@ahumandev/autocode",
  "version": "0.0.3",
  "type": "module",
  "private": false,
  "main": "./dist/plugin.js",
  "types": "./dist/plugin.d.ts",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ahumandev/autocode.git"
  },
  "homepage": "https://github.com/ahumandev/autocode#readme",
  "bugs": {
    "url": "https://github.com/ahumandev/autocode/issues"
  },
  "keywords": [
    "opencode",
    "opencode-plugin",
    "ai-agents",
    "agent-workflow",
    "job-workflow",
    "workflow-automation",
    "developer-tools"
  ],
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/plugin.d.ts",
      "default": "./dist/plugin.js"
    }
  },
  "scripts": {
    "build": "rm -rf dist && bun build src/plugin.ts --outdir dist --target bun && tsc --emitDeclarationOnly --noEmit false && bun run copy:skills",
    "install:shim": "bun scripts/install-plugin-shim.mjs",
    "watch": "rm -rf dist && bun run copy:skills && bun build src/plugin.ts --outdir dist --target bun --watch & tsc --emitDeclarationOnly --noEmit false --watch",
    "copy:skills": "bun scripts/copy-skill-sources.mjs",
    "test": "bun test src",
    "typecheck": "tsc --noEmit",
    "verify:package": "node scripts/verify-package-artifacts.mjs",
    "prepublishOnly": "bun run test && bun run typecheck && bun run build && bun run verify:package",
    "verify:sandbox-online": "node scripts/verify-sandbox-online.mjs"
  },
  "dependencies": {
    "@opencode-ai/plugin": "1.14.28",
    "@opencode-ai/sdk": "1.14.28",
    "gray-matter": "^4.0.3"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.5.0"
  }
}