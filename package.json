{
  "name": "@ahumandev/autocode",
  "version": "0.6.1",
  "type": "module",
  "private": false,
  "main": "./dist/plugin.js",
  "types": "./dist/plugin.d.ts",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ahumandev/autocode.git"
  },
  "homepage": "https://ahumandev.github.io/autocode",
  "bugs": {
    "url": "https://github.com/ahumandev/autocode/issues"
  },
  "keywords": [
    "opencode",
    "opencode-plugin",
    "ai-agents",
    "agent-workflow",
    "job-workflow",
    "workflow-automation",
    "developer-tools"
  ],
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/plugin.d.ts",
      "default": "./dist/plugin.js"
    }
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "rm -rf dist && bun build src/plugin.ts --outdir dist --target bun && tsc --project tsconfig.build.json --emitDeclarationOnly --noEmit false && bun run copy:skills",
    "install:shim": "bun src/install.ts",
    "watch": "rm -rf dist && bun run copy:skills && bun build src/plugin.ts --outdir dist --target bun --watch & tsc --project tsconfig.build.json --emitDeclarationOnly --noEmit false --watch",
    "copy:skills": "bun scripts/copy-skill-sources.ts",
    "skill:sync": "bun scripts/sync-github-skills.ts",
    "test": "bun test src --isolate",
    "typecheck": "tsc --noEmit",
    "verify:package": "bun scripts/verify-package-artifacts.ts",
    "release:version": "bun scripts/release-version.ts",
    "prepublishOnly": "bun run test && bun run typecheck && bun run build && bun run verify:package",
    "verify:sandbox-online": "node scripts/verify-sandbox-online.mjs"
  },
  "dependencies": {
    "@opencode-ai/plugin": "^1.17.18",
    "@opencode-ai/sdk": "^1.17.18",
    "gray-matter": "4.0.3",
    "jsonc-parser": "3.3.1",
    "ssh2": "1.17.0",
    "yaml": "2.9.0"
  },
  "devDependencies": {
    "@types/bun": "1.3.14",
    "@types/ssh2": "1.15.5",
    "fast-check": "4.9.0",
    "typescript": "6.0.3"
  }
}
